APP_NAME="MENZO QR"
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# The PUBLIC URL of THIS backend (Laravel), no trailing slash.
#   Local:      http://localhost:8000
#   Production: https://<your-service>.up.railway.app   (or your custom domain)
# This is used to build every dish/logo/QR *image_url* returned by the API
# (Storage::disk('public')->url()). If this is wrong, images will look like
# they "don't exist" in the frontend even though the files are on disk.
APP_URL=http://localhost:8000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en

# The PUBLIC URL of the Next.js frontend, no trailing slash. This is what
# gets embedded (indirectly, via the /qr/{code} redirect) inside every
# generated QR code image, and is the base of the public menu link:
# {APP_FRONTEND_URL}/menu/{cafeSlug}
#   Local:      http://localhost:3000
#   Production: https://<your-project>.vercel.app   (or your custom domain)
APP_FRONTEND_URL=http://localhost:3000

# Comma-separated list of origins allowed to call this API (config/cors.php).
# Must match APP_FRONTEND_URL (and any preview/staging domains) exactly,
# including scheme — https://app.vercel.app is NOT the same origin as
# https://www.app.vercel.app or http://app.vercel.app.
FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug
# On Railway, uncomment the two lines below: the filesystem is ephemeral, so
# writing logs to storage/logs/*.log means `railway logs` shows nothing.
# LOG_CHANNEL=stderr
# LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=menzo_qr
DB_USERNAME=postgres
DB_PASSWORD=
# On Railway with Neon, set these from the connection string Neon gives you,
# or simply set DATABASE_URL to Neon's connection string instead — Laravel
# 12 reads DATABASE_URL automatically if present.
# DATABASE_URL=postgresql://user:password@host/db?sslmode=require

SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Where dish photos, cafe logos, and generated QR images are stored.
#   public -> local disk at storage/app/public, served via /storage/...
#             ⚠️ Railway's filesystem is EPHEMERAL: files here are LOST on
#             every redeploy/restart unless you attach a Railway Volume
#             mounted at the app's storage/app/public directory.
#   s3     -> any S3-compatible bucket (AWS S3, Cloudflare R2, Backblaze B2).
#             Recommended for production if you don't want to manage a
#             Volume. Fill in the AWS_* vars below and set FILESYSTEM_DISK=s3.
FILESYSTEM_DISK=public

# Only needed if FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@menzoqr.local"
MAIL_FROM_NAME="${APP_NAME}"

# First Owner account, created once by OwnerSeeder on `php artisan migrate --seed`
# (only if the users table is empty). Leave blank to skip seeding an owner.
OWNER_NAME="Owner"
OWNER_EMAIL=
OWNER_PHONE=
OWNER_PASSWORD=

# Telegram bot integration — optional, leave blank until you have a real
# Bot Token. Never commit real values.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
